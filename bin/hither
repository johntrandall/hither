#!/bin/bash
# SPDX-License-Identifier: MIT
# bin/hither — CLI entry point.
#
# Subcommands (v0.3.0):
#   bootstrap [--reapply-only|--user-only|--root-only]
#                                Install/repair Hither on this Mac
#   subscribe <nas> --user <u>   Add a NAS subscription
#   unsubscribe <nas> [--purge]  Remove a NAS subscription
#   list                         Show subscribed NASes
#   sync [<nas>]                 Manual fire of the sync (all subs or one)
#   status                       Show daemon + config + mount state
#   unmount <nas>|<n>/<s>|all    Force-unmount shares
#   remount <nas>|all            Unmount + automount -cv
#   logs [<nas>] [--tail]        Tail or grep the sync log
#   doctor                       Check mount health, Keychain, TM exclusion
#   verify-no-leaks              Pre-commit privacy gate
#   uninstall [--purge]          Reverse of bootstrap
#   version                      Print version
#
# Resolves its own location via readlink -f so the symlink at
# ~/.local/bin/hither (created by lash install) still finds the
# sibling scripts in the repo.

set -euo pipefail

# --- Locate the project root (symlink-safe) ---
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_ROOT="$(cd "$(dirname "${SCRIPT_PATH}")/.." && pwd)"
export HITHER_ROOT="${PROJECT_ROOT}"

HITHER_VERSION="0.5.2"
VERSION="${HITHER_VERSION}"  # back-compat for any external consumer
export HITHER_VERSION

# --- Source shared subscription/config helpers ---
# shellcheck source=../libexec/hither-lib.sh
. "${HITHER_ROOT}/libexec/hither-lib.sh"

usage() {
  cat <<EOF
hither ${HITHER_VERSION} — lazy mounter for personal Mac SMB fleets

Usage:
  hither bootstrap [--reapply-only|--user-only|--root-only]
      Install (or re-apply) /etc/synthetic.conf, /etc/auto_master, the
      hither-write-map wrapper, the LaunchDaemon (revert defender), and
      the LaunchAgent (daily sync). Idempotent. Reboot required after
      first install to materialize /Hither.

      Two phases:
        sudo \$(which hither) bootstrap        # root phase
        hither bootstrap --user-only           # user phase

  hither subscribe <nas> --user <dsm-user> [--proto http|https]
                                            [--schedule-hour H]
                                            [--schedule-minute M]
                                            [--notify=true|false]
      Add a NAS subscription. Prompts for the DSM password (or reads it
      from stdin if piped), stores it in macOS Keychain, writes the
      subscription file to ~/.config/hither/subscriptions/<nas>.toml,
      and triggers an initial sync.

      --notify=true (default) fires a macOS user notification on
      subsequent syncs when the set of shares this user can see on the
      NAS changes (shares added or removed).

  hither unsubscribe <nas> [--purge]
      Remove a NAS subscription. Unmounts any shares, deletes the
      subscription file, and removes /etc/auto_master + /etc/hither_<nas>.
      --purge also deletes the Keychain entry (irreversible).

  hither list
      Tabular view of subscriptions: NAS / user / proto / schedule /
      share count / last sync age.

  hither sync [<nas>] [--notify|--no-notify|--notify=true|--notify=false]
      Fire the sync now. Without args: every subscription. With <nas>:
      that one only. --notify / --no-notify (and the =true/=false forms)
      override the global notify_on_changes for this one invocation; the
      default is the any-true OR-aggregation across all subscriptions
      (matches the scheduled LaunchAgent's behavior).

  hither status
      One-screen status: both daemons' load state, file state,
      per-subscription state including stale-mount detection.

  hither unmount <nas> | <nas>/<share> | all
      Force-unmount with umount -f.

  hither remount <nas> | all
      Unmount + automount -cv (sudo). Useful after autofs gets stuck.

  hither logs [<nas>] [--tail]
      Show the sync log. With <nas>: filter to entries for that NAS.
      With --tail: follow the log.

  hither doctor
      Verify mounts, Keychain, TM exclusion, both daemons loaded.

  hither verify-no-leaks [<path>]
      Run the pre-commit privacy gate.

  hither uninstall [--purge]
      Reverse of bootstrap. Two phases (user + root); --purge also
      removes subscription config and Keychain entries. Synthetic-root
      removal takes effect only after reboot.

  hither version

EOF
}

die() { echo "ERROR: $*" >&2; exit 1; }

# =============================================================================
# bootstrap
# =============================================================================

bootstrap_root_phase() {
  local reapply_only="$1"

  echo "=== Hither bootstrap — root phase (reapply_only=${reapply_only}) ==="

  # 1. Install/re-apply synthetic.conf entry + materialize /Hither
  bash "${HITHER_ROOT}/bootstrap/add-synthetic-root.sh"

  # 2. Install/re-apply /etc/auto_master entry for each subscribed host.
  #    v0.3 reads the subscriber list from ~/.config/hither/subscriptions/.
  #    First-time installs have an empty list — the loop is a no-op and we
  #    print a hint to run `hither subscribe`.
  #
  #    NOTE: when running as root via sudo, $HOME is root's home. We want
  #    the invoking user's subscription dir, which sudo passes via SUDO_USER.
  local target_home="${HOME}"
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    target_home="$(eval echo "~${SUDO_USER}")"
  fi
  local subs_dir="${target_home}/.config/hither/subscriptions"
  local found_any=0
  if [[ -d "${subs_dir}" ]]; then
    local sub
    for sub in "${subs_dir}"/*.toml; do
      [[ -f "$sub" ]] || continue
      local host
      host="$(basename "$sub" .toml)"
      bash "${HITHER_ROOT}/bootstrap/apply-auto-master.sh" "${host}"
      found_any=1
    done
  fi
  if [[ "${found_any}" -eq 0 ]]; then
    echo "[hint] no subscriptions found at ${subs_dir} — run 'hither subscribe <nas> --user <dsm-user>' after bootstrap"
  fi

  if [[ "$reapply_only" -eq 1 ]]; then
    echo "=== bootstrap root phase complete (reapply-only) ==="
    return 0
  fi

  # 3. Wrapper script.
  install -m 0755 -o root -g wheel \
    "${HITHER_ROOT}/sbin/hither-write-map" \
    /usr/local/sbin/hither-write-map
  echo "[ok] installed /usr/local/sbin/hither-write-map"

  # 3b. Sudoers grant for the wrapper. Validate the source with visudo
  # BEFORE installing — a malformed sudoers file would lock the user out
  # of sudo entirely. Install at 0440 root:wheel per sudoers convention.
  if ! visudo -cf "${HITHER_ROOT}/sudoers/hither-write-map" >/dev/null; then
    die "${HITHER_ROOT}/sudoers/hither-write-map failed visudo -cf — refusing to install"
  fi
  install -m 0440 -o root -g wheel \
    "${HITHER_ROOT}/sudoers/hither-write-map" \
    /etc/sudoers.d/hither-write-map
  echo "[ok] installed /etc/sudoers.d/hither-write-map"

  # 3c. Remove the legacy v0.1/v0.2 sudoers file if present. Pre-v0.3.0
  # installs shipped a sudoers file at /etc/sudoers.d/xysat-hither-sync
  # granting a specific service account; v0.3.0+ ships
  # /etc/sudoers.d/hither-write-map granting %admin (the generic, public
  # form). This block is a no-op on fresh installs — only runs if the
  # old file is present from an upgrade path.
  # Legacy file from the pre-v0.2 centrally-scheduled era; remove if present.
  if [[ -f /etc/sudoers.d/xysat-hither-sync ]]; then
    rm -f /etc/sudoers.d/xysat-hither-sync
    echo "[ok] removed legacy /etc/sudoers.d/xysat-hither-sync"
  fi

  # 4. libexec scripts.
  install -d -m 0755 -o root -g wheel /usr/local/libexec/hither
  install -m 0755 -o root -g wheel \
    "${HITHER_ROOT}/bootstrap/add-synthetic-root.sh" \
    /usr/local/libexec/hither/add-synthetic-root.sh
  install -m 0755 -o root -g wheel \
    "${HITHER_ROOT}/bootstrap/apply-auto-master.sh" \
    /usr/local/libexec/hither/apply-auto-master.sh
  install -m 0755 -o root -g wheel \
    "${HITHER_ROOT}/libexec/hither-sync.sh" \
    /usr/local/libexec/hither/hither-sync.sh
  echo "[ok] installed /usr/local/libexec/hither/{add-synthetic-root,apply-auto-master,hither-sync}.sh"

  # 5. LaunchDaemon.
  bash "${HITHER_ROOT}/bootstrap/install-launchdaemon.sh"

  echo "=== bootstrap root phase complete ==="
  echo
  echo "Next: run the user phase (without sudo) to install the LaunchAgent:"
  echo "      hither bootstrap --user-only"
}

bootstrap_user_phase() {
  if [[ $EUID -eq 0 ]]; then
    die "bootstrap --user-only must NOT be run as root — LaunchAgents live in user home"
  fi

  echo "=== Hither bootstrap — user phase (uid=$(id -u)) ==="

  local agent_dir="${HOME}/Library/LaunchAgents"
  local agent_dst="${HITHER_AGENT_PATH}"
  local agent_src="${HITHER_ROOT}/launchd/com.johnrandall.hither.sync.plist"

  [[ -f "${agent_src}" ]] || die "LaunchAgent template not found at ${agent_src}"

  mkdir -p "${agent_dir}"
  mkdir -p "${HOME}/Library/Logs/hither"

  # Substitute __HOME__ at install time. launchd does NOT expand env vars
  # in plist paths.
  sed "s|__HOME__|${HOME}|g" "${agent_src}" > "${agent_dst}.tmp"
  chmod 0644 "${agent_dst}.tmp"
  mv "${agent_dst}.tmp" "${agent_dst}"
  echo "[ok] installed ${agent_dst}"

  plutil -lint "${agent_dst}" >/dev/null || die "${agent_dst} failed plutil -lint after install"

  # If we have subscriptions, re-render the env block now. Otherwise the
  # plist sits with its template placeholder values — they won't be used
  # until the user runs `hither subscribe`, which calls
  # refresh_launchagent_env to materialize the real env block.
  if [[ -n "$(hither_sub_list_names)" ]]; then
    hither_refresh_launchagent_env
  else
    local domain="gui/$(id -u)"
    launchctl bootout "${domain}/${HITHER_AGENT_LABEL}" 2>/dev/null || true
    launchctl bootstrap "${domain}" "${agent_dst}" \
      || die "launchctl bootstrap ${domain} failed"
    echo "[ok] LaunchAgent loaded into ${domain} (no subscriptions yet — use 'hither subscribe')"
  fi

  echo "=== bootstrap user phase complete ==="
}

cmd_bootstrap() {
  local reapply_only=0 user_only=0 root_only=0
  for arg in "$@"; do
    case "$arg" in
      --reapply-only) reapply_only=1 ;;
      --user-only)    user_only=1 ;;
      --root-only)    root_only=1 ;;
      *) die "unknown arg to bootstrap: $arg" ;;
    esac
  done

  if [[ $user_only -eq 1 ]]; then
    bootstrap_user_phase
    return
  fi

  if [[ $EUID -ne 0 ]]; then
    echo "ERROR: bootstrap requires root — run via: sudo \$(which hither) bootstrap" >&2
    echo "       Or run just the user phase (no sudo): hither bootstrap --user-only" >&2
    exit 1
  fi

  bootstrap_root_phase "$reapply_only"
  [[ $root_only -eq 1 ]] && return
}

# =============================================================================
# subscribe / unsubscribe / list
# =============================================================================

cmd_subscribe() {
  if [[ $EUID -eq 0 ]]; then
    die "'hither subscribe' must NOT be run as root — Keychain write needs user session"
  fi

  # v0.5: notify defaults to "true" — new subscriptions opt in by default.
  # Existing pre-v0.5 subscription files that lack the field stay at
  # default-false at read time (see hither_sub_read_notify), so this only
  # affects new installs.
  local nas="" user="" proto="http" hour="4" minute="23" notify="true"
  if [[ $# -lt 1 ]]; then
    die "usage: hither subscribe <nas> --user <dsm-user> [--proto http|https] [--schedule-hour H] [--schedule-minute M] [--notify=true|false]"
  fi
  # Guard against `hither subscribe --user foo`: $1 here would be `--user`,
  # which would silently become the nas name. Require a positional nas first.
  if [[ "$1" == --* ]]; then
    die "first arg to subscribe must be the NAS name, not a flag (got '$1'); usage: hither subscribe <nas> --user <dsm-user>"
  fi
  nas="$1"; shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user)            user="$2"; shift 2 ;;
      --proto)           proto="$2"; shift 2 ;;
      --schedule-hour)   hour="$2"; shift 2 ;;
      --schedule-minute) minute="$2"; shift 2 ;;
      --notify=true)     notify="true"; shift ;;
      --notify=false)    notify="false"; shift ;;
      --notify)          notify="true"; shift ;;
      --no-notify)       notify="false"; shift ;;
      *) die "unknown arg to subscribe: $1" ;;
    esac
  done

  hither_validate_nas_name "${nas}" \
    || die "nas name '${nas}' invalid — must match ^[a-z0-9-]+\$"
  [[ -n "${user}" ]] \
    || die "--user <dsm-user> is required"
  [[ "${proto}" == "http" || "${proto}" == "https" ]] \
    || die "--proto must be 'http' or 'https' (got '${proto}')"
  if ! [[ "${hour}" =~ ^[0-9]+$ ]] || (( hour < 0 || hour > 23 )); then
    die "--schedule-hour must be 0-23 (got '${hour}')"
  fi
  if ! [[ "${minute}" =~ ^[0-9]+$ ]] || (( minute < 0 || minute > 59 )); then
    die "--schedule-minute must be 0-59 (got '${minute}')"
  fi

  if hither_sub_exists "${nas}"; then
    echo "[warn] subscription ${nas} already exists at $(hither_sub_path "${nas}") — overwriting"
  fi

  # Read password. Pipe-detection: if stdin is not a TTY, slurp one line
  # from it (test pattern: `hither subscribe foo --user u <<< 'pw'`).
  local password=""
  if [[ ! -t 0 ]]; then
    IFS= read -r password
  else
    printf 'DSM password for %s@%s (input hidden): ' "${user}" "${nas}" >&2
    IFS= read -rs password
    echo >&2
  fi
  [[ -n "${password}" ]] || die "empty password — refusing to store"

  # Store credential. Use -U so a re-subscribe overwrites cleanly.
  if ! security add-internet-password -U \
      -s "${nas}" -a "${user}" -r 'smb ' \
      -w "${password}" 2>/dev/null; then
    die "security add-internet-password failed for ${user}@${nas}"
  fi
  echo "[ok] Keychain entry stored for ${user}@${nas}"

  # Write subscription file.
  hither_sub_write "${nas}" "${user}" "${proto}" "${hour}" "${minute}" "${notify}"
  echo "[ok] wrote $(hither_sub_path "${nas}") (notify_on_changes=${notify})"

  # Apply auto_master entry. Requires sudo. We attempt sudo -n first; if
  # that fails, document the next step and don't block.
  if [[ -x /usr/local/libexec/hither/apply-auto-master.sh ]]; then
    if sudo -n /usr/local/libexec/hither/apply-auto-master.sh "${nas}" >/dev/null 2>&1; then
      echo "[ok] /etc/auto_master entry applied (sudo -n succeeded)"
    else
      echo "[hint] /etc/auto_master not updated automatically — run:"
      echo "       sudo /usr/local/libexec/hither/apply-auto-master.sh ${nas}"
      echo "       (Or re-run 'sudo \$(which hither) bootstrap --reapply-only')"
    fi
  else
    echo "[hint] /usr/local/libexec/hither/apply-auto-master.sh not installed — run 'sudo \$(which hither) bootstrap' first"
  fi

  # Refresh LaunchAgent env block to include the new NAS.
  hither_refresh_launchagent_env || echo "[warn] LaunchAgent refresh failed; sync will use stale NAS_LIST until next 'hither bootstrap --user-only'"

  # Trigger initial sync (just this NAS). HITHER_NOTIFY=0 unconditionally
  # here — the initial-sync gate in hither-sync.sh also suppresses
  # notifications when there's no prior on-disk map, but we belt-and-
  # suspenders it at the CLI layer so the very first run on a brand-new
  # subscription never fires a notification.
  echo "[run] initial sync for ${nas}"
  if [[ -x /usr/local/libexec/hither/hither-sync.sh ]]; then
    TARGET_USER="${user}" NAS_LIST="${nas}" NAS_PROTO="${proto}" HITHER_NOTIFY="0" \
      /usr/local/libexec/hither/hither-sync.sh \
      || echo "[warn] initial sync exited non-zero — check ~/Library/Logs/hither/sync.log"
  else
    echo "[hint] /usr/local/libexec/hither/hither-sync.sh not installed — run 'sudo \$(which hither) bootstrap' first"
  fi

  echo "=== subscribed to ${nas} ==="
}

cmd_unsubscribe() {
  if [[ $EUID -eq 0 ]]; then
    die "'hither unsubscribe' must NOT be run as root"
  fi

  local nas="" purge=0
  if [[ $# -lt 1 ]]; then
    die "usage: hither unsubscribe <nas> [--purge]"
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --purge) purge=1; shift ;;
      *)
        if [[ -z "$nas" ]]; then
          nas="$1"; shift
        else
          die "unexpected arg: $1"
        fi
        ;;
    esac
  done
  [[ -n "$nas" ]] || die "usage: hither unsubscribe <nas> [--purge]"

  hither_validate_nas_name "${nas}" \
    || die "nas name '${nas}' invalid — must match ^[a-z0-9-]+\$"

  # 1. Best-effort unmount of any currently-mounted shares.
  if [[ -d "/Hither/${nas}" ]]; then
    local mp
    while IFS= read -r mp; do
      [[ -n "$mp" ]] || continue
      echo "[run] umount -f ${mp}"
      umount -f "${mp}" 2>/dev/null || true
    done < <(mount | awk -v p="/Hither/${nas}/" '$0 ~ "on "p {for(i=1;i<=NF;i++) if($i=="on"){print $(i+1); break}}')
  fi

  # 2. Delete subscription file.
  if hither_sub_exists "${nas}"; then
    hither_sub_delete "${nas}"
    echo "[ok] removed $(hither_sub_path "${nas}")"
  else
    echo "[skip] no subscription file at $(hither_sub_path "${nas}")"
  fi

  # 3. Remove /etc/auto_master line (needs sudo).
  if grep -qE "^/Hither/${nas}[[:space:]]" /etc/auto_master 2>/dev/null; then
    if sudo -n sed -i.bak "/^\\/Hither\\/${nas}[[:space:]]/d" /etc/auto_master 2>/dev/null; then
      echo "[ok] removed /Hither/${nas} line from /etc/auto_master"
      sudo -n /usr/sbin/automount -cv >/dev/null 2>&1 || true
    else
      echo "[hint] /etc/auto_master line still present — run:"
      echo "       sudo sed -i.bak '/^\\/Hither\\/${nas}[[:space:]]/d' /etc/auto_master && sudo automount -cv"
    fi
  fi

  # 4. Remove /etc/hither_<nas>.
  if [[ -f "/etc/hither_${nas}" ]]; then
    if sudo -n rm -f "/etc/hither_${nas}" "/etc/hither_${nas}.needs-reload" 2>/dev/null; then
      echo "[ok] removed /etc/hither_${nas}"
    else
      echo "[hint] /etc/hither_${nas} still present — run: sudo rm /etc/hither_${nas}"
    fi
  fi

  # 5. Refresh LaunchAgent env (or note that nothing's left).
  hither_refresh_launchagent_env || true

  # 6. --purge: delete Keychain entry.
  if [[ $purge -eq 1 ]]; then
    if security delete-internet-password -s "${nas}" >/dev/null 2>&1; then
      echo "[ok] --purge: deleted Keychain entry for ${nas}"
    else
      echo "[skip] --purge: no Keychain entry found for ${nas}"
    fi
  else
    echo "[hint] Keychain entry preserved. To delete: hither unsubscribe ${nas} --purge"
  fi

  echo "=== unsubscribed from ${nas} ==="
}

cmd_list() {
  local nas user proto hour minute map shares last_sync last_age_h
  local count=0
  printf '%-12s %-16s %-6s %-9s %-7s %s\n' \
    "NAS" "USER" "PROTO" "SCHEDULE" "SHARES" "LAST SYNC"
  while IFS=$'\t' read -r nas user proto hour minute; do
    [[ -n "$nas" ]] || continue
    count=$((count + 1))

    # SHARES: count non-comment, non-blank lines in /etc/hither_<nas>.
    map="/etc/hither_${nas}"
    if [[ -r "${map}" ]]; then
      # grep -c prints "0" on its own when there are no matches; `|| echo 0`
      # would double-output because grep also exits 1 in that case. Capture
      # just grep's output; exit code is acceptable.
      shares=$(grep -cvE '^[[:space:]]*(#|$)' "${map}" 2>/dev/null) || shares=0
    else
      shares="-"
    fi

    # LAST SYNC: mtime of /etc/hither_<nas>.
    if [[ -r "${map}" ]]; then
      last_sync=$(stat -f '%m' "${map}" 2>/dev/null || echo "")
      if [[ -n "${last_sync}" ]]; then
        local now age_min
        now=$(date +%s)
        age_min=$(( (now - last_sync) / 60 ))
        if (( age_min < 60 )); then
          last_age_h="${age_min}m ago"
        elif (( age_min < 1440 )); then
          last_age_h="$(( age_min / 60 ))h ago"
        else
          last_age_h="$(( age_min / 1440 ))d ago"
        fi
      else
        last_age_h="-"
      fi
    else
      last_age_h="never"
    fi

    printf '%-12s %-16s %-6s %02d:%02d     %-7s %s\n' \
      "$nas" "$user" "$proto" "$hour" "$minute" "$shares" "$last_age_h"
  done < <(hither_sub_iter)

  if [[ ${count} -eq 0 ]]; then
    echo
    echo "(no subscriptions — run: hither subscribe <nas> --user <dsm-user>)"
  fi
}

# =============================================================================
# sync (extended) / status / unmount / remount / logs
# =============================================================================

cmd_sync() {
  if [[ $EUID -eq 0 ]]; then
    die "'hither sync' must NOT be run as root — Keychain access requires user GUI session"
  fi

  # Parse flags. The target_nas is the first non-flag positional arg
  # (legacy: `hither sync [<nas>]`). v0.5 adds --notify / --no-notify
  # for one-shot override of the subscription's notify_on_changes.
  local target_nas="" notify_override=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --notify)    notify_override="1"; shift ;;
      --no-notify) notify_override="0"; shift ;;
      --notify=true)  notify_override="1"; shift ;;
      --notify=false) notify_override="0"; shift ;;
      --*) die "unknown flag to sync: $1" ;;
      *)
        if [[ -z "${target_nas}" ]]; then
          target_nas="$1"; shift
        else
          die "unexpected positional arg to sync: $1"
        fi
        ;;
    esac
  done

  local subs
  subs="$(hither_sub_list_names)"

  # Check for subscriptions FIRST so a user on an unbootstrapped machine
  # gets the more actionable hint (subscribe to add a NAS) rather than the
  # less useful one (sudo bootstrap), unless they have neither.
  if [[ -z "${subs}" && -z "${target_nas}" ]]; then
    if [[ ! -x /usr/local/libexec/hither/hither-sync.sh ]]; then
      die "no subscriptions and Hither isn't installed yet — first run: sudo \$(which hither) bootstrap, then: hither subscribe <nas> --user <dsm-user>"
    fi
    echo "[hint] no subscriptions yet — run: hither subscribe <nas> --user <dsm-user>"
    return 0
  fi

  [[ -x /usr/local/libexec/hither/hither-sync.sh ]] \
    || die "/usr/local/libexec/hither/hither-sync.sh not installed — run: sudo \$(which hither) bootstrap"

  if [[ -n "${target_nas}" ]]; then
    hither_validate_nas_name "${target_nas}" \
      || die "nas name '${target_nas}' invalid"
    hither_sub_exists "${target_nas}" \
      || die "no subscription for ${target_nas} — run: hither subscribe ${target_nas} --user <dsm-user>"
    local path user proto sub_notify hn
    path="$(hither_sub_path "${target_nas}")"
    user="$(hither_sub_read_field "${path}" user)"
    proto="$(hither_sub_read_field "${path}" nas_proto)"
    sub_notify="$(hither_sub_read_notify "${path}")"
    if [[ -n "${notify_override}" ]]; then
      hn="${notify_override}"
    elif [[ "${sub_notify}" == "true" ]]; then
      hn="1"
    else
      hn="0"
    fi
    TARGET_USER="${user}" NAS_LIST="${target_nas}" NAS_PROTO="${proto}" HITHER_NOTIFY="${hn}" \
      exec /usr/local/libexec/hither/hither-sync.sh
  fi

  # All subscriptions. Iterate (assume single TARGET_USER + proto; warned
  # in refresh_launchagent_env for multi-user). HITHER_NOTIFY defaults to
  # any-true across subscriptions — matches hither_refresh_launchagent_env's
  # OR-aggregation so a manual `hither sync` and a scheduled LaunchAgent
  # fire behave identically. --notify / --no-notify override.
  local first_user="" first_proto="" notify_any="0"
  local nas_list="" iter_nas iter_user iter_proto seen_first=0
  while IFS=$'\t' read -r iter_nas iter_user iter_proto _ _; do
    [[ -n "$iter_nas" ]] || continue
    if (( seen_first == 0 )); then
      first_user="$iter_user"
      first_proto="$iter_proto"
      seen_first=1
    fi
    if [[ "$(hither_sub_read_notify "$(hither_sub_path "$iter_nas")")" == "true" ]]; then
      notify_any="1"
    fi
    if [[ -z "$nas_list" ]]; then nas_list="$iter_nas"
    else nas_list="${nas_list} ${iter_nas}"; fi
  done < <(hither_sub_iter)

  local hn
  if [[ -n "${notify_override}" ]]; then
    hn="${notify_override}"
  else
    hn="${notify_any}"
  fi

  TARGET_USER="${first_user}" NAS_LIST="${nas_list}" NAS_PROTO="${first_proto}" HITHER_NOTIFY="${hn}" \
    exec /usr/local/libexec/hither/hither-sync.sh
}

cmd_status() {
  echo "Hither ${HITHER_VERSION}"
  echo

  # --- Daemons ---
  local ld_state ag_state ld_last ag_last ag_next
  if sudo -n launchctl print system/com.johnrandall.hither.bootstrap >/dev/null 2>&1; then
    ld_state="loaded"
  elif launchctl print system/com.johnrandall.hither.bootstrap >/dev/null 2>&1; then
    ld_state="loaded"
  else
    ld_state="NOT loaded"
  fi

  if launchctl print "gui/$(id -u)/com.johnrandall.hither.sync" >/dev/null 2>&1; then
    ag_state="loaded"
  else
    ag_state="NOT loaded"
  fi
  ld_last="(check /var/log/hither/)"
  ag_last="(check ~/Library/Logs/hither/sync.log)"
  ag_next="04:23 next"

  printf '  %-46s %-12s %s\n' "com.johnrandall.hither.bootstrap" "${ld_state}" "${ld_last}"
  printf '  %-46s %-12s %s   %s\n' "com.johnrandall.hither.sync" "${ag_state}" "${ag_last}" "${ag_next}"
  echo

  # --- Files ---
  if grep -qE '^Hither[[:space:]]' /etc/synthetic.conf 2>/dev/null; then
    if grep -qE $'^Hither\tSystem/Volumes/Data/Hither$' /etc/synthetic.conf; then
      printf '  %-46s %s\n' "/etc/synthetic.conf" "ok (symlink form)"
    else
      printf '  %-46s %s\n' "/etc/synthetic.conf" "WARN (non-symlink form)"
    fi
  else
    printf '  %-46s %s\n' "/etc/synthetic.conf" "MISSING Hither entry"
  fi

  local am_count
  am_count=$(grep -cE '^/Hither/' /etc/auto_master 2>/dev/null) || am_count=0
  printf '  %-46s %s\n' "/etc/auto_master" "ok (${am_count} /Hither/ entries)"

  if [[ -L /Hither ]]; then
    printf '  %-46s %s\n' "/Hither" "ok -> $(readlink /Hither)"
  elif [[ -d /Hither ]]; then
    printf '  %-46s %s\n' "/Hither" "ok (dir form)"
  else
    printf '  %-46s %s\n' "/Hither" "MISSING"
  fi
  echo

  # --- Subscriptions ---
  local count=0 nas user proto hour minute mount_count stale_count
  while IFS=$'\t' read -r nas user proto hour minute; do
    [[ -n "$nas" ]] || continue
    count=$((count + 1))

    local map="/etc/hither_${nas}"
    local shares="-"
    local last_age="never"
    if [[ -r "$map" ]]; then
      shares=$(grep -cvE '^[[:space:]]*(#|$)' "$map" 2>/dev/null) || shares=0
      local mt now age_min
      mt=$(stat -f '%m' "$map" 2>/dev/null || echo "")
      if [[ -n "$mt" ]]; then
        now=$(date +%s); age_min=$(( (now - mt) / 60 ))
        if (( age_min < 60 )); then last_age="${age_min}m ago"
        elif (( age_min < 1440 )); then last_age="$(( age_min / 60 ))h ago"
        else last_age="$(( age_min / 1440 ))d ago"; fi
      fi
    fi

    mount_count=0; stale_count=0
    local mp
    while IFS= read -r mp; do
      [[ -n "$mp" ]] || continue
      mount_count=$((mount_count + 1))
      if ! timeout 2 stat -f '%t' "${mp}" >/dev/null 2>&1; then
        stale_count=$((stale_count + 1))
      fi
    done < <(mount | awk -v p="/Hither/${nas}/" '$0 ~ "on "p {for(i=1;i<=NF;i++) if($i=="on"){print $(i+1); break}}')

    printf '  %-12s ok   %s shares    last_sync %s    %d mounted, %d stale\n' \
      "$nas" "$shares" "$last_age" "$mount_count" "$stale_count"
  done < <(hither_sub_iter)

  if [[ ${count} -eq 0 ]]; then
    echo "  (no subscriptions — run: hither subscribe <nas> --user <dsm-user>)"
  fi
}

# Helper: list currently-mounted paths under /Hither/<nas>/
hither_mounts_under() {
  local nas="$1"
  mount | awk -v p="/Hither/${nas}/" '$0 ~ "on "p {for(i=1;i<=NF;i++) if($i=="on"){print $(i+1); break}}'
}

cmd_unmount() {
  [[ $# -ge 1 ]] || die "usage: hither unmount <nas> | <nas>/<share> | all"
  local target="$1"

  do_umount() {
    local mp="$1"
    if umount -f "${mp}" 2>/dev/null; then
      echo "  [ok] umount -f ${mp}"
    else
      echo "  [warn] umount -f ${mp} (rc=$?)"
    fi
  }

  if [[ "${target}" == "all" ]]; then
    local nas
    while IFS= read -r nas; do
      [[ -n "$nas" ]] || continue
      echo "== ${nas} =="
      local mp
      while IFS= read -r mp; do
        [[ -n "$mp" ]] || continue
        do_umount "${mp}"
      done < <(hither_mounts_under "${nas}")
    done < <(hither_sub_list_names)
    return
  fi

  if [[ "${target}" == */* ]]; then
    local nas="${target%%/*}"
    local share="${target#*/}"
    hither_validate_nas_name "${nas}" || die "invalid nas name in '${target}'"
    do_umount "/Hither/${nas}/${share}"
    return
  fi

  hither_validate_nas_name "${target}" || die "invalid nas name '${target}'"
  echo "== ${target} =="
  local mp
  while IFS= read -r mp; do
    [[ -n "$mp" ]] || continue
    do_umount "${mp}"
  done < <(hither_mounts_under "${target}")
}

cmd_remount() {
  [[ $# -ge 1 ]] || die "usage: hither remount <nas> | all"
  cmd_unmount "$1"
  echo "== reload autofs =="
  if sudo /usr/sbin/automount -cv >/dev/null 2>&1; then
    echo "  [ok] automount -cv"
  else
    echo "  [warn] automount -cv failed (sudo cached creds expired?)"
  fi
}

cmd_logs() {
  local log_file="${HOME}/Library/Logs/hither/sync.log"
  local tail=0 target_nas=""
  for arg in "$@"; do
    case "$arg" in
      --tail) tail=1 ;;
      *)
        if [[ -z "${target_nas}" ]]; then
          target_nas="$arg"
        else
          die "unexpected arg: $arg"
        fi
        ;;
    esac
  done

  [[ -f "${log_file}" ]] \
    || die "no log file at ${log_file} — has the LaunchAgent fired yet?"

  if [[ -n "${target_nas}" ]]; then
    hither_validate_nas_name "${target_nas}" \
      || die "nas name '${target_nas}' invalid"
  fi

  if [[ $tail -eq 1 ]]; then
    if [[ -n "${target_nas}" ]]; then
      exec tail -F "${log_file}" | grep --line-buffered -E "(processing ${target_nas}|hither_${target_nas})"
    else
      exec tail -F "${log_file}"
    fi
  fi

  if [[ -n "${target_nas}" ]]; then
    grep -E "(processing ${target_nas}|hither_${target_nas})" "${log_file}" || true
  else
    cat "${log_file}"
  fi
}

# =============================================================================
# doctor / verify-no-leaks / uninstall / version
# =============================================================================

cmd_doctor() {
  bash "${HITHER_ROOT}/scripts/doctor.sh" "$@"
}

cmd_verify_no_leaks() {
  bash "${HITHER_ROOT}/scripts/verify-no-leaks.sh" "$@"
}

cmd_uninstall() {
  local purge=0
  for arg in "$@"; do
    case "$arg" in
      --purge) purge=1 ;;
      *) die "unknown arg to uninstall: $arg" ;;
    esac
  done

  # --- User phase ---
  if [[ $EUID -ne 0 ]]; then
    echo "=== Hither uninstall — user phase (uid=$(id -u)) ==="
    local domain="gui/$(id -u)"
    launchctl bootout "${domain}/${HITHER_AGENT_LABEL}" 2>/dev/null \
      && echo "[ok] LaunchAgent booted out" \
      || echo "[skip] LaunchAgent was not loaded"
    if [[ -f "${HITHER_AGENT_PATH}" ]]; then
      rm -f "${HITHER_AGENT_PATH}"
      echo "[ok] removed ${HITHER_AGENT_PATH}"
    fi

    if [[ $purge -eq 1 ]]; then
      local nas
      while IFS= read -r nas; do
        [[ -n "$nas" ]] || continue
        security delete-internet-password -s "${nas}" >/dev/null 2>&1 \
          && echo "[ok] --purge: deleted Keychain entry for ${nas}" \
          || echo "[skip] --purge: no Keychain entry for ${nas}"
      done < <(hither_sub_list_names)
      if [[ -d "${HITHER_CONFIG_DIR}" ]]; then
        # Use `trash` if available so it's recoverable.
        if command -v trash >/dev/null 2>&1; then
          trash "${HITHER_CONFIG_DIR}" \
            && echo "[ok] --purge: trashed ${HITHER_CONFIG_DIR}"
        else
          rm -rf "${HITHER_CONFIG_DIR}" \
            && echo "[ok] --purge: removed ${HITHER_CONFIG_DIR}"
        fi
      fi
    fi

    echo
    echo "Next: run the root phase to remove system files:"
    # purge is 0/1; only suggest --purge when the user actually asked for it.
    # `${purge:+...}` is wrong here — it expands when purge is set AND non-empty,
    # and "0" is non-empty so it would always suggest --purge (silently destructive).
    if [[ "$purge" -eq 1 ]]; then
      echo "      sudo \$(which hither) uninstall --purge"
    else
      echo "      sudo \$(which hither) uninstall"
    fi
    return
  fi

  # --- Root phase ---
  echo "=== Hither uninstall — root phase ==="

  launchctl bootout system/com.johnrandall.hither.bootstrap 2>/dev/null \
    && echo "[ok] LaunchDaemon booted out" \
    || echo "[skip] LaunchDaemon was not loaded"
  rm -f /Library/LaunchDaemons/com.johnrandall.hither.bootstrap.plist \
    && echo "[ok] removed /Library/LaunchDaemons/com.johnrandall.hither.bootstrap.plist"

  rm -f /usr/local/sbin/hither-write-map \
    && echo "[ok] removed /usr/local/sbin/hither-write-map"

  rm -f /etc/sudoers.d/hither-write-map \
    && echo "[ok] removed /etc/sudoers.d/hither-write-map"
  # Also clean up the legacy v0.1/v0.2 sudoers file if still present.
  # Legacy file from the pre-v0.2 centrally-scheduled era; remove if present.
  if [[ -f /etc/sudoers.d/xysat-hither-sync ]]; then
    rm -f /etc/sudoers.d/xysat-hither-sync \
      && echo "[ok] removed legacy /etc/sudoers.d/xysat-hither-sync"
  fi

  rm -rf /usr/local/libexec/hither \
    && echo "[ok] removed /usr/local/libexec/hither/"

  # Strip /Hither lines from /etc/synthetic.conf and /etc/auto_master.
  if [[ -f /etc/synthetic.conf ]]; then
    sed -i.bak '/^Hither[[:space:]]/d' /etc/synthetic.conf \
      && echo "[ok] removed Hither line from /etc/synthetic.conf (.bak preserved)"
  fi
  if [[ -f /etc/auto_master ]]; then
    sed -i.bak '/^\/Hither\//d' /etc/auto_master \
      && echo "[ok] removed /Hither lines from /etc/auto_master (.bak preserved)"
    /usr/sbin/automount -cv >/dev/null 2>&1 || true
  fi

  # /etc/hither_* maps + markers (best-effort).
  rm -f /etc/hither_* 2>/dev/null && echo "[ok] removed /etc/hither_* maps"

  echo
  echo "[note] /Hither synthetic root removal takes effect only after reboot."
  echo "       The directory will remain visible until the next boot rebuilds /etc/synthetic.conf state."
}

cmd_version() {
  echo "hither ${HITHER_VERSION}"
}

# =============================================================================
# Dispatch
# =============================================================================

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

subcmd="$1"
shift

case "$subcmd" in
  bootstrap)          cmd_bootstrap "$@" ;;
  subscribe)          cmd_subscribe "$@" ;;
  unsubscribe)        cmd_unsubscribe "$@" ;;
  list)               cmd_list "$@" ;;
  sync)               cmd_sync "$@" ;;
  status)             cmd_status "$@" ;;
  unmount)            cmd_unmount "$@" ;;
  remount)            cmd_remount "$@" ;;
  logs)               cmd_logs "$@" ;;
  doctor)             cmd_doctor "$@" ;;
  verify-no-leaks)    cmd_verify_no_leaks "$@" ;;
  uninstall)          cmd_uninstall "$@" ;;
  version|--version|-v) cmd_version ;;
  help|--help|-h)     usage ;;
  *)                  echo "ERROR: unknown subcommand '${subcmd}'" >&2; usage; exit 2 ;;
esac
